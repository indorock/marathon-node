{
  "name": "marathon-node",
  "version": "1.0.0",
  "description": "Marathon Training Countdown — Node/Express/TypeScript port",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsup && sed -i '' 's/from \"sqlite\"/from \"node:sqlite\"/g' dist/app.js && cp -r views public dist/",
    "start": "node dist/app.js",
    "seed:sqlite": "tsx db/seed.ts",
    "seed:mongo": "tsx db/seed-mongo.ts",
    "dev": "tsx watch app.ts"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.10",
    "mongodb": "^6.5.0",
    "cookie-parser": "^1.4.6",
    "ejs": "^3.1.9",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/xmldom": "^0.1.34",
    "tsup": "^8.0.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
